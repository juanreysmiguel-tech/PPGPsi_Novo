# Renomeie/copie para .env.development.local (na raiz) para usar Firebase Emulator + npm run dev.
# Antes: npm run emulators (exige Java JDK 17+). Ver README.md.

VITE_USE_FIREBASE_EMULATORS=true
VITE_FIREBASE_API_KEY=demo-key
VITE_FIREBASE_AUTH_DOMAIN=demo-ppgpsi.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=demo-ppgpsi
VITE_FIREBASE_STORAGE_BUCKET=demo-ppgpsi.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789012
VITE_FIREBASE_APP_ID=1:123456789012:web:ppgpsi-demo
