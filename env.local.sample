# 1) Copie ESTE arquivo e salve como .env.local (com ponto no inicio), na raiz do ppgpsi-web.
# 2) Preencha com o SDK do seu app Web no Firebase Console (Configuracoes > Seus apps).
# 3) Reinicie o terminal do npm run dev.
#
# Nao commite .env.local (ja esta no .gitignore via *.local).

VITE_USE_FIREBASE_EMULATORS=false
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
